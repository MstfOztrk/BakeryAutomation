<Application x:Class="BakeryAutomation.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BakeryAutomation.ViewModels"
             xmlns:views="clr-namespace:BakeryAutomation.Views"
             StartupUri="MainWindow.xaml">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <views:DashboardView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ProductsViewModel}">
                <views:ProductsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:BranchesViewModel}">
                <views:BranchesView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ShipmentsViewModel}">
                <views:ShipmentsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:PaymentsViewModel}">
                <views:PaymentsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ReturnsViewModel}">
                <views:ReturnsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
                <views:ReportsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
