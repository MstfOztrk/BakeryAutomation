<UserControl x:Class="BakeryAutomation.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Raporlar" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBlock Text="Muhasebe icin daha detayli ozet, cari kirilimi ve ekstre akisini buradan alin."
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,0,0,12" />

            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Filtreler" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />

                    <WrapPanel Margin="0,0,0,10">
                        <TextBlock Text="Rapor:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold" />
                        <RadioButton GroupName="ReportType" Content="Gunluk Muhasebe Ozeti" IsChecked="{Binding IsDailyMode}" Command="{Binding RefreshCommand}" Margin="0,0,15,0" VerticalAlignment="Center" />
                        <RadioButton GroupName="ReportType" Content="Cari Ekstre" IsChecked="{Binding IsStatementMode}" Command="{Binding RefreshCommand}" VerticalAlignment="Center" />
                    </WrapPanel>

                    <WrapPanel>
                        <StackPanel Width="180" Margin="0,0,12,0">
                            <TextBlock Text="Baslangic" Foreground="{DynamicResource TextMutedBrush}" />
                            <DatePicker SelectedDate="{Binding From}" />
                        </StackPanel>
                        <StackPanel Width="180" Margin="0,0,12,0">
                            <TextBlock Text="Bitis" Foreground="{DynamicResource TextMutedBrush}" />
                            <DatePicker SelectedDate="{Binding To}" />
                        </StackPanel>
                        <StackPanel Width="280" Margin="0,0,12,0">
                            <TextBlock Text="Cari" Foreground="{DynamicResource TextMutedBrush}" />
                            <ComboBox ItemsSource="{Binding Branches}" DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding BranchId}" />
                        </StackPanel>
                        <StackPanel Width="280">
                            <TextBlock Text=" " />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Style="{StaticResource PrimaryButton}" Command="{Binding RefreshCommand}" Content="Uygula" />
                                <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Command="{Binding ExportCsvCommand}" Content="CSV Aktar" />
                            </Grid>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="{Binding ReportScopeTitle}" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding ReportScopeDescription}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Donem" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="{Binding PeriodText}" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <WrapPanel Margin="0,0,0,12">
                <Border Style="{StaticResource CardBorder}" Width="220" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="Devreden Bakiye" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="{Binding OpeningBalance, StringFormat={}{0:n2}}" FontSize="24" FontWeight="SemiBold" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding OpeningBalanceNote}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Width="220" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="Kapanis Bakiyesi" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="{Binding ClosingBalance, StringFormat={}{0:n2}}" FontSize="24" FontWeight="SemiBold" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding ClosingBalanceNote}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Width="220" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="Sevkiyat" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="{Binding TotalRevenue, StringFormat={}{0:n2}}" FontSize="24" FontWeight="SemiBold" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding ShipmentCardNote}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Width="220" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="Iade" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="{Binding TotalReturns, StringFormat={}{0:n2}}" FontSize="24" FontWeight="SemiBold" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding ReturnCardNote}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Width="220" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="Net Ciro" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="{Binding TotalNetRevenue, StringFormat={}{0:n2}}" FontSize="24" FontWeight="SemiBold" Margin="0,4,0,0" />
                        <TextBlock Text="Sevkiyat - iade" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Width="220" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="Tahsilat" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="{Binding TotalPayments, StringFormat={}{0:n2}}" FontSize="24" FontWeight="SemiBold" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding PaymentCardNote}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Width="220" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="Tahsilat Orani" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="{Binding CollectionRate, StringFormat={}{0:P1}}" FontSize="24" FontWeight="SemiBold" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding CollectionRateNote}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Width="220" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="Iade Orani" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="{Binding ReturnRate, StringFormat={}{0:P1}}" FontSize="24" FontWeight="SemiBold" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding ReturnRateNote}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </WrapPanel>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Cari Bazli Ozet" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="Devreden ve kapanis bakiyesiyle birlikte donem ici hareket kirilimi."
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,4,0,10" />

                        <DataGrid ItemsSource="{Binding BranchSummaryRows}" IsReadOnly="True" AutoGenerateColumns="False" Height="280">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Cari" Binding="{Binding BranchName}" Width="*" />
                                <DataGridTextColumn Header="Tip" Binding="{Binding TypeDisplay}" Width="90" />
                                <DataGridTextColumn Header="Vade / Tahsilat" Binding="{Binding TermsDisplay}" Width="190" />
                                <DataGridTextColumn Header="Devreden" Binding="{Binding OpeningBalance, StringFormat={}{0:n2}}" Width="110" />
                                <DataGridTextColumn Header="Sevkiyat" Binding="{Binding ShipmentAmount, StringFormat={}{0:n2}}" Width="110" />
                                <DataGridTextColumn Header="Iade" Binding="{Binding ReturnAmount, StringFormat={}{0:n2}}" Width="110" />
                                <DataGridTextColumn Header="Net Ciro" Binding="{Binding NetRevenue, StringFormat={}{0:n2}}" Width="110" />
                                <DataGridTextColumn Header="Tahsilat" Binding="{Binding Payments, StringFormat={}{0:n2}}" Width="110" />
                                <DataGridTextColumn Header="Kapanis" Binding="{Binding ClosingBalance, StringFormat={}{0:n2}}" Width="110" />
                                <DataGridTextColumn Header="Kredi" Binding="{Binding CreditStatus}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Tahsilat Dagilimi" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="Odeme yontemine gore tahsilat toplamlari ve payi."
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,4,0,10" />

                        <DataGrid ItemsSource="{Binding PaymentMethodRows}" IsReadOnly="True" AutoGenerateColumns="False" Height="280">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Yontem" Binding="{Binding MethodName}" Width="*" />
                                <DataGridTextColumn Header="Adet" Binding="{Binding Count}" Width="70" />
                                <DataGridTextColumn Header="Tutar" Binding="{Binding Amount, StringFormat={}{0:n2}}" Width="110" />
                                <DataGridTextColumn Header="Pay" Binding="{Binding Share, StringFormat={}{0:P1}}" Width="80" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="{Binding DetailTitle}" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DetailHint}"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,4,0,10" />

                    <DataGrid ItemsSource="{Binding Rows}" IsReadOnly="True" AutoGenerateColumns="False" Height="420">
                        <DataGrid.Style>
                            <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStatementMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Style>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tarih" Binding="{Binding Date, StringFormat={}{0:yyyy-MM-dd}}" Width="120" />
                            <DataGridTextColumn Header="Devreden" Binding="{Binding OpeningBalance, StringFormat={}{0:n2}}" Width="110" />
                            <DataGridTextColumn Header="Fis Adedi" Binding="{Binding ShipmentCount}" Width="80" />
                            <DataGridTextColumn Header="Sevkiyat" Binding="{Binding ShipmentAmount, StringFormat={}{0:n2}}" Width="110" />
                            <DataGridTextColumn Header="Iade Adedi" Binding="{Binding ReturnCount}" Width="85" />
                            <DataGridTextColumn Header="Iade" Binding="{Binding ReturnAmount, StringFormat={}{0:n2}}" Width="110" />
                            <DataGridTextColumn Header="Net Ciro" Binding="{Binding NetRevenue, StringFormat={}{0:n2}}" Width="110" />
                            <DataGridTextColumn Header="Tahsilat Adedi" Binding="{Binding PaymentCount}" Width="100" />
                            <DataGridTextColumn Header="Tahsilat" Binding="{Binding Payments, StringFormat={}{0:n2}}" Width="110" />
                            <DataGridTextColumn Header="Gun Sonu" Binding="{Binding ClosingBalance, StringFormat={}{0:n2}}" Width="110" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <DataGrid ItemsSource="{Binding StatementRows}" IsReadOnly="True" AutoGenerateColumns="False" Height="420">
                        <DataGrid.Style>
                            <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStatementMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Style>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tarih" Binding="{Binding Date, StringFormat={}{0:yyyy-MM-dd}}" Width="120" />
                            <DataGridTextColumn Header="Cari" Binding="{Binding BranchName}" Width="180" />
                            <DataGridTextColumn Header="Islem" Binding="{Binding TransactionType}" Width="110" />
                            <DataGridTextColumn Header="Belge / Ref" Binding="{Binding DocumentNo}" Width="130" />
                            <DataGridTextColumn Header="Aciklama" Binding="{Binding Description}" Width="*" />
                            <DataGridTextColumn Header="Borc" Binding="{Binding Debt, StringFormat={}{0:n2}}" Width="100" Foreground="#FFDC2626" />
                            <DataGridTextColumn Header="Alacak" Binding="{Binding Credit, StringFormat={}{0:n2}}" Width="100" Foreground="#FF059669" />
                            <DataGridTextColumn Header="Bakiye" Binding="{Binding Balance, StringFormat={}{0:n2}}" Width="110" FontWeight="Bold" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
