<UserControl x:Class="BakeryAutomation.Views.ShipmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:BakeryAutomation.Services">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,12">
            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ShipmentsTitle]}" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="Gunluk sevkiyatlari ve satir iadelerini birlikte yonetin."
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="370" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorder}" Margin="0,0,12,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Style="{StaticResource PrimaryButton}" Command="{Binding NewBatchCommand}" Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[New]}" />
                            <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Command="{Binding RefreshCommand}" Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Refresh]}" />
                        </Grid>

                        <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="4" Padding="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="30" />
                                </Grid.ColumnDefinitions>
                                <Button services:CommandButtonFeedback.IsEnabled="False" Command="{Binding PreviousDayCommand}" Content="&lt;" Style="{StaticResource SecondaryButton}" Padding="0" Height="24" />
                                <DatePicker Grid.Column="1" SelectedDate="{Binding FilterDate}" Margin="4,0" VerticalAlignment="Center" BorderThickness="0" Background="Transparent" />
                                <Button Grid.Column="2" services:CommandButtonFeedback.IsEnabled="False" Command="{Binding NextDayCommand}" Content="&gt;" Style="{StaticResource SecondaryButton}" Padding="0" Height="24" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="300" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ListBox ItemsSource="{Binding Batches}" SelectedItem="{Binding SelectedRow}" DisplayMemberPath="Display" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                    <Setter Property="Padding" Value="10" />
                                    <Setter Property="FontSize" Value="14" />
                                    <Setter Property="Margin" Value="0,0,0,4" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ShipmentNo]}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="Gray"
                                       Margin="4,0,0,4" />

                            <ListBox Grid.Row="1" ItemsSource="{Binding Items}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock TextTrimming="CharacterEllipsis">
                                                <Run Text="{Binding QuantitySent, StringFormat={}{0:G}x}" FontWeight="Bold" />
                                                <Run Text=" " />
                                                <Run Text="{Binding ProductName}" />
                                                <Run Text=" " />
                                                <Run Text="{Binding UnitPrice, StringFormat={}{0:n2} TL}" Foreground="#6B7280" FontSize="11" />
                                            </TextBlock>
                                            <TextBlock Grid.Column="1" Text="{Binding TotalLinePrice, StringFormat={}{0:n2}}" FontWeight="SemiBold" Margin="8,0,0,0" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <Border Grid.Row="2" Background="{DynamicResource BackgroundBrush}" Padding="12" Margin="0,8,0,0" CornerRadius="4">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,4">
                                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Total]}" Foreground="{DynamicResource TextMutedBrush}" />
                                    <TextBlock Text="{Binding TotalGross, StringFormat={}{0:n2}}" HorizontalAlignment="Right" FontWeight="SemiBold" />
                                </DockPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TotalDiscount]}" Foreground="#EF4444" />
                                    <TextBlock Text="{Binding TotalDiscount, StringFormat={}-{0:n2}}" HorizontalAlignment="Right" Foreground="#EF4444" />
                                </DockPanel>
                                <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,6" />
                                <DockPanel>
                                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[GeneralTotal]}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Total, StringFormat={}{0:n2}}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Right" />
                                </DockPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Style="{StaticResource SecondaryButton}" Command="{Binding RecalculateCommand}" Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Recalculate]}" />
                        <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Command="{Binding PrintCommand}" Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Print]}" />
                        <Button Grid.Column="4" Style="{StaticResource SecondaryButton}" Command="{Binding ExportBatchCommand}" Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Export]}" />
                        <Button Grid.Column="6" Style="{StaticResource DangerButton}" Command="{Binding DeleteBatchCommand}" Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Delete]}" />
                    </Grid>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Product]}" Binding="{Binding ProductName}" Width="*" IsReadOnly="True" />
                            <DataGridTextColumn Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Unit]}" Binding="{Binding UnitTypeDisplay, Mode=OneWay}" Width="80" IsReadOnly="True" />
                            <DataGridTextColumn Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Sent]}" Binding="{Binding QuantitySent, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                            <DataGridTextColumn Header="Ayni Fis Iade" Binding="{Binding QuantityReturned, UpdateSourceTrigger=PropertyChanged}" Width="110" />
                            <DataGridTextColumn Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Wasted]}" Binding="{Binding QuantityWasted, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                            <DataGridTextColumn Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[UnitPrice]}" Binding="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                            <DataGridTextColumn Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Discount]}" Binding="{Binding ItemDiscountPercent, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2" Background="{DynamicResource BackgroundBrush}" CornerRadius="8" Padding="15" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[SubTotal]}" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" FontSize="14" />
                            <TextBlock Text="{Binding Subtotal, StringFormat={}{0:n2}}" Margin="8,0,0,0" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text=" | " Foreground="{DynamicResource TextMutedBrush}" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="14" />
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Total]}" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" FontSize="14" />
                            <TextBlock Text="{Binding Total, StringFormat={}{0:n2}}" Margin="8,0,0,0" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="3" Margin="0,10,0,10">
                        <TextBlock Text="Bu iade alani ayni fis icindir. Sonraki iadeleri Iadeler ekranindan girin."
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,4" />

                        <TextBlock Text="{Binding SelectedItemStatusText}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Button Grid.Row="4"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding RemoveItemCommand}"
                            Content="{Binding RemoveItemButtonText}"
                            Width="220"
                            HorizontalAlignment="Left" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{Binding BatchEditorTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />

                        <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                            <TextBlock Text="{Binding BatchEditorHint}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       TextWrapping="Wrap" />
                        </Border>

                        <TextBlock Text="{Binding BatchStatusText}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,0,0,10" />

                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ShipmentNo]}" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBox Text="{Binding BatchNo, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Date]}" Foreground="{DynamicResource TextMutedBrush}" />
                        <DatePicker SelectedDate="{Binding Date}" />

                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Branch]}" Foreground="{DynamicResource TextMutedBrush}" />
                        <ComboBox ItemsSource="{Binding Branches}" DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding BranchId}" />

                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Discount]}" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBox Text="{Binding BatchDiscountPercent, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Note]}" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="78" />

                        <TextBlock Text="{Binding SaveBatchFeedback}"
                                   Foreground="#86EFAC"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,4">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSaveBatchFeedback}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Button Command="{Binding SaveBatchCommand}"
                                Content="{Binding SaveBatchButtonText}"
                                Width="140"
                                HorizontalAlignment="Left"
                                Margin="0,10,0,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSaveBatchSuccessActive}" Value="True">
                                            <Setter Property="Background" Value="#16A34A" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Separator Margin="0,10,0,10" />
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AddToShipment]}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6" />

                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Product]}" Foreground="{DynamicResource TextMutedBrush}" />
                        <ComboBox ItemsSource="{Binding Products}" DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding NewProductId}" />

                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Sent]}" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBox Text="{Binding NewQtySent, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[UnitPrice]}" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBox Text="{Binding NewUnitPrice, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Discount]}" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBox Text="{Binding NewItemDiscountPercent, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="{Binding ItemAddFeedback}"
                                   Foreground="#86EFAC"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,4">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasItemAddFeedback}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Button Command="{Binding AddItemCommand}" Content="{Binding AddItemButtonText}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsItemAddSuccessActive}" Value="True">
                                            <Setter Property="Background" Value="#16A34A" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
