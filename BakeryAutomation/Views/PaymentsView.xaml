<UserControl x:Class="BakeryAutomation.Views.PaymentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,12">
            <TextBlock Text="Tahsilat Masasi" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="Once bir cari secin; o carinin acik fislerini, net bakiyesini ve tahsilat gecmisini ayni ekranda yonetin."
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorder}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Text="Cariler" FontSize="16" FontWeight="SemiBold" />
                        <TextBlock Text="En yuksek bakiyeli cariler ustte listelenir."
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Branches}"
                             SelectedItem="{Binding SelectedBranchRow}"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,10,10,12"
                                        Margin="0,0,0,2"
                                        Background="Transparent"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       DockPanel.Dock="Right" />
                                        </DockPanel>
                                        <TextBlock Text="{Binding TypeDisplay}"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding BalanceText}" Margin="0,8,0,0" />
                                        <TextBlock Text="{Binding OpenShipmentsText}" Foreground="{DynamicResource TextMutedBrush}" />
                                        <TextBlock Text="{Binding LastPaymentText}" Foreground="{DynamicResource TextMutedBrush}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="{Binding SelectedBranchName}" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedBranchMeta}"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Button Style="{StaticResource SecondaryButton}"
                                    Command="{Binding RefreshCommand}"
                                    Content="Yenile"
                                    Width="110"
                                    DockPanel.Dock="Right"
                                    Margin="12,0,0,0" />
                        </DockPanel>

                        <Grid Margin="0,14,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{DynamicResource BackgroundBrush}" CornerRadius="10" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Net Bakiye" Foreground="{DynamicResource TextMutedBrush}" />
                                    <TextBlock Text="{Binding SelectedBranchBalance, StringFormat={}{0:n2}}" FontSize="18" FontWeight="SemiBold" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="{DynamicResource BackgroundBrush}" CornerRadius="10" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Acik Fis Adedi" Foreground="{DynamicResource TextMutedBrush}" />
                                    <TextBlock Text="{Binding SelectedBranchOpenShipmentCount}" FontSize="18" FontWeight="SemiBold" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4" Background="{DynamicResource BackgroundBrush}" CornerRadius="10" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Acik Fis Toplami" Foreground="{DynamicResource TextMutedBrush}" />
                                    <TextBlock Text="{Binding SelectedBranchOpenShipmentAmount, StringFormat={}{0:n2}}" FontSize="18" FontWeight="SemiBold" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="6" Background="{DynamicResource BackgroundBrush}" CornerRadius="10" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Son Tahsilat" Foreground="{DynamicResource TextMutedBrush}" />
                                    <TextBlock Text="{Binding SelectedBranchLastPayment}" FontWeight="SemiBold" Margin="0,6,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="10" Padding="12">
                            <TextBlock Text="{Binding SelectedBranchReconciliationHint}"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock Text="Acik Fisler" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="Satira tiklayinca sagdaki tahsilat formu o fisin kalanina hazirlanir."
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <DataGrid ItemsSource="{Binding OpenShipments}"
                                  SelectedItem="{Binding SelectedOpenShipment}"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tarih" Binding="{Binding Date, StringFormat={}{0:yyyy-MM-dd}}" Width="120" />
                                <DataGridTextColumn Header="Fis No" Binding="{Binding BatchNo}" Width="160" />
                                <DataGridTextColumn Header="Fis Tutari" Binding="{Binding Total, StringFormat={}{0:n2}}" Width="120" />
                                <DataGridTextColumn Header="Iade" Binding="{Binding Returns, StringFormat={}{0:n2}}" Width="100" />
                                <DataGridTextColumn Header="Alinan" Binding="{Binding Paid, StringFormat={}{0:n2}}" Width="110" />
                                <DataGridTextColumn Header="Kalan" Binding="{Binding Remaining, StringFormat={}{0:n2}}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <Border Grid.Row="4" Style="{StaticResource CardBorder}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock Text="Tahsilat Gecmisi" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="Bir tahsilat secerseniz sagdaki form duzenleme moduna gecer."
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <DataGrid ItemsSource="{Binding PaymentHistory}"
                                  SelectedItem="{Binding SelectedRow}"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tarih" Binding="{Binding Payment.Date, StringFormat={}{0:yyyy-MM-dd}}" Width="120" />
                                <DataGridTextColumn Header="Tip" Binding="{Binding KindDisplay}" Width="100" />
                                <DataGridTextColumn Header="Fis No" Binding="{Binding ShipmentDisplay}" Width="140" />
                                <DataGridTextColumn Header="Tutar" Binding="{Binding Payment.Amount, StringFormat={}{0:n2}}" Width="120" />
                                <DataGridTextColumn Header="Yontem" Binding="{Binding MethodDisplay}" Width="130" />
                                <DataGridTextColumn Header="Aciklama" Binding="{Binding Payment.Note}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <Border Grid.Column="4" Style="{StaticResource CardBorder}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel IsEnabled="{Binding HasSelectedBranch}">
                        <TextBlock Text="{Binding EntryTitle}" FontSize="16" FontWeight="SemiBold" />

                        <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="10" Padding="12" Margin="0,12,0,12">
                            <StackPanel>
                                <TextBlock Text="{Binding EntryModeText}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding EntryHint}"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding GeneralPaymentCommand}"
                                    Content="Serbest Tahsilat" />
                            <Button Grid.Column="2"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding GeneralReturnCommand}"
                                    Content="Serbest Iade" />
                            <Button Grid.Column="4"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding FillRemainingAmountCommand}"
                                    Content="Kalani Yaz" />
                        </Grid>

                        <TextBlock Text="Cari" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="{Binding SelectedBranchName}" FontWeight="SemiBold" Margin="0,0,0,12" />

                        <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasShipmentSelection}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="Bu tahsilat herhangi bir fise baglanmadan dogrudan cari bakiyesinden duser."
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       TextWrapping="Wrap" />
                        </Border>

                        <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,12">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasShipmentSelection}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedShipmentDisplay}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedShipmentTotal, StringFormat=Fis Tutari: {0:n2}}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0" />
                                <TextBlock Text="{Binding SelectedShipmentReturns, StringFormat=Iade: {0:n2}}" Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Text="{Binding SelectedShipmentPaid, StringFormat=Alinan Tahsilat: {0:n2}}" Foreground="{DynamicResource TextMutedBrush}" />
                                <TextBlock Text="{Binding SelectedShipmentRemaining, StringFormat=Kalan: {0:n2}}" FontWeight="SemiBold" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Tarih" Foreground="{DynamicResource TextMutedBrush}" />
                        <DatePicker SelectedDate="{Binding Date}" />

                        <TextBlock Text="Tutar" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Yontem" Foreground="{DynamicResource TextMutedBrush}" />
                        <ComboBox ItemsSource="{Binding PaymentMethods}" DisplayMemberPath="Name" SelectedValuePath="Value" SelectedValue="{Binding Method}" />

                        <TextBlock Text="Referans" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBox Text="{Binding Reference, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Not" Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="90" />

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Style="{StaticResource SecondaryButton}" Command="{Binding NewCommand}" Content="Yeni" />
                            <Button Grid.Column="2" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" Content="Kaydet" />
                            <Button Grid.Column="4" Style="{StaticResource DangerButton}" Command="{Binding DeleteCommand}" Content="Sil" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
