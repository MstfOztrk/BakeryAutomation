<UserControl x:Class="BakeryAutomation.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:BakeryAutomation.Services">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Ayarlar" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12" />

            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Veri" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />

                    <TextBlock Text="Veri Klasoru" Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBox Text="{Binding DataFolder, Mode=OneWay}" IsReadOnly="True" />

                    <TextBlock Text="Veri Dosyasi" Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBox Text="{Binding DataFile, Mode=OneWay}" IsReadOnly="True" />

                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Style="{StaticResource SecondaryButton}" Command="{Binding OpenFolderCommand}" Content="Klasoru Ac" />
                        <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Command="{Binding BackupCommand}" Content="Yedek Al" />
                        <Button Grid.Column="4" Style="{StaticResource SecondaryButton}" Command="{Binding RestoreCommand}" Content="Geri Yukle" />
                        <Button Grid.Column="6" Style="{StaticResource SecondaryButton}" Command="{Binding ReloadCommand}" Content="Veriyi Yenile" />
                    </Grid>

                    <TextBlock Text="Geri yukleme sonrasi uygulamayi yeniden acin."
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}" Margin="0,10,0,0">
                <StackPanel>
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Language]}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <ComboBox ItemsSource="{Binding Languages}" DisplayMemberPath="Name" SelectedValuePath="Value" SelectedValue="{Binding SelectedLanguage}" HorizontalAlignment="Left" Width="220" Margin="0,0,0,20" />

                    <TextBlock Text="Tema" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding SelectedTheme}" HorizontalAlignment="Left" Width="220" Margin="0,0,0,20" />

                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DatabaseSettings]}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <TextBlock Text="Tema ve dil ayarlari bu cihazda saklanir."
                               Foreground="{DynamicResource TextMutedBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
